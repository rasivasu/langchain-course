# Git ignore configuration for LangChain MCP Adapters project
# This file prevents committing sensitive data, build artifacts, and development files

# Environment variables
# DO NOT COMMIT .env files - they contain sensitive API keys and credentials
.env
.env.local
.env.*.local

# Python
# Compiled Python files and bytecode caches
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
# Don't commit virtual environment directories - they're large and system-specific
venv/
ENV/
env/
.venv/

# IDEs
# Ignore editor and IDE configuration files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
# Don't commit test artifacts and coverage reports
.pytest_cache/
.tox/
.coverage
htmlcov/

# LangChain/LangSmith
# Ignore local caches created by LangChain and LangSmith
.langchain/
.langsmith/

# Project-specific
# Don't commit log files or temporary cache directories
*.log
.cache/
